// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum UserRole {
  USER
  ADMIN
}

enum MessageRole {
  system
  user
  assistant
  data
}

enum MessageType {
  TEXT
  IMAGE
}

// --- Models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER) // 기본값은 유저, 최초 가입 시 이메일 체크로 ADMIN 승격

  // NextAuth 필수 관계
  accounts Account[]
  sessions Session[]

  // AI 기능 관련
  chats      Chat[]
  characters Character[]

  // 액세스 코드 연결: 유저가 어떤 코드를 통해 가입/인증되었는지 기록
  accessCodeId String?
  accessCode   AccessCode? @relation(fields: [accessCodeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model AccessCode {
  id        String    @id @default(cuid())
  code      String    @unique
  maxUses   Int       @default(10) // 이 코드로 가입 가능한 최대 인원
  usedCount Int       @default(0) // 현재까지 사용한 인원
  expiresAt DateTime? // 코드 만료일 (선택 사항)
  isActive  Boolean   @default(true)

  users User[] // 이 코드를 사용하는 유저들

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Character {
  id   String @id @default(cuid())
  name String // 캐릭터 이름

  // 캐릭터 기본 설정
  personality String? @db.Text // 성격
  speechStyle String? @db.Text // 말투
  appearance  String? @db.Text // 외모
  imageUrl    String? // 캐릭터 이미지 (추후 사용을 위해 선택 사항으로 배치)

  // 스토리 및 롤플레이 설정
  genre     String? // 장르 (예: 판타지, 로맨스, 무협 등)
  worldview String? @db.Text // 세계관 및 스토리 배경 설정
  castSetup String? @db.Text // 기타 등장인물 외모, 성격, 말투 등 세부 설정

  customPrompt String? @db.Text // 유저가 직접 작성한 시스템 프롬프트 (이 값이 있으면 다른 세부 설정보다 우선 적용)
  isPublic     Boolean @default(false) // 다른 유저에게 이 캐릭터를 공개할지 여부

  // 생성자(유저)와의 관계
  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  // 이 캐릭터와 연결된 대화방들
  chats Chat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId])
}

model Chat {
  id    String  @id @default(cuid())
  title String? @default("새로운 대화")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  messages Message[]

  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([characterId])
  @@index([createdAt(sort: Desc)])
}

model Message {
  id     String @id @default(cuid())
  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  role    MessageRole @default(user)
  content String      @db.Text

  type MessageType @default(TEXT)

  // 2차 목표(이미지 생성)를 위한 확장 필드
  // AI SDK 사용 시 필요한 메타데이터 (이미지 URL, 모델 정보 등)
  metadata Json?

  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([createdAt])
}

// --- NextAuth 필수 모델 (Auth.js 표준) ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
